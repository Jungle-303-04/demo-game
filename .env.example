# Set this to the PC's LAN IPv4 so phones on the same network can join by QR.
PUBLIC_GAME_HOST=192.168.0.10

# Keep 10 for the full presentation. Use 2-3 on a memory-constrained laptop.
OPSIA_MIN_BOTS_PER_ROOM=10

# Optional: relay the orchestrator's durable operation events to Opsia.
# OPSIA_EVENT_ENDPOINT=http://host.docker.internal:18080/agent/game-operation-events
# OPSIA_AGENT_TOKEN=<registered cluster-agent token>
# OPSIA_WORKSPACE_ID=<workspace id bound to that token>
# OPSIA_CLUSTER_ID=<cluster id bound to that token>

# Set this to the PC's LAN IPv4 so phones on the same network can join by QR.
PUBLIC_GAME_HOST=192.168.0.10

# Keep 10 for the full presentation. Use 2-3 on a memory-constrained laptop.
OPSIA_MIN_BOTS_PER_ROOM=1
# Keep this off for high bot counts. Enable it only for small tactical demos.
OPSIA_BOT_TACTICAL_BRAIN=false
# Players, guns, loot, and breakable crates only; safe to keep on at high bot counts.
OPSIA_BOT_LIGHTWEIGHT_COMBAT=true
OPSIA_BOT_STARTER_GUN=hk416
OPSIA_SNAPSHOT_INTERVAL_MS=5000

# Admission failure demo: after it is explicitly armed, this many real join
# requests in the rolling window terminate only the admission API (exit 70).
ADMISSION_OVERLOAD_THRESHOLD_REQUESTS=35
ADMISSION_OVERLOAD_WINDOW_MS=1000
ADMISSION_OVERLOAD_EXIT_CODE=70

# Optional: relay the orchestrator's durable operation events to Opsia.
# OPSIA_EVENT_ENDPOINT=http://host.docker.internal:18080/agent/game-operation-events
# OPSIA_AGENT_TOKEN=<registered cluster-agent token>
# OPSIA_WORKSPACE_ID=<workspace id bound to that token>
# OPSIA_CLUSTER_ID=<cluster id bound to that token>
